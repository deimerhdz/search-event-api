{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "watchOptions": {
    "ignored": [
      "node_modules",
      ".cache",
      "**/.cache/**",
      "**/huggingface/**",
      "C:/Users/PC/.cache/huggingface"
    ]
  }
}
